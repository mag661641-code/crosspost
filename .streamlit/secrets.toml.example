# Шаблон секретов Streamlit. Скопируйте этот файл в secrets.toml (без .example)
# и впишите реальные значения — secrets.toml в git не попадёт (см. .gitignore).
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml

API_BASE = "http://localhost:3900"

[project_passwords]
SMU = "ваш-пароль"
IMP = "ваш-пароль"
MPE = "ваш-пароль"
