# Зависимости — ставятся через npm install / pip install, в репозиторий не нужны
node_modules/
__pycache__/
*.pyc

# Личные данные: пароли соцсетей, куки, профили браузера, загруженные картинки, логи
users-data/

# Локальные логи Streamlit/Node
*.log

# Секреты Streamlit (пароли, адрес сервера) — никогда не коммитить
.streamlit/secrets.toml
